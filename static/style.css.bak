:root{
  --bg:#eaf1f7;--card:#fff;--navy:#06142c;--line:#2f3f59;--cyan:#8ed1dc;--blue:#0b66d6;--yellow:#ffc000;--muted:#6b7280;
}
*{box-sizing:border-box}
body{margin:0;font-family:Arial,Helvetica,sans-serif;background:var(--bg);color:#000;overflow:hidden}
.topbar{height:68px;display:flex;align-items:center;gap:9px;padding:6px 14px;background:#f7fbff;border-top:4px solid #111;border-bottom:1px solid #c8d5e5;position:sticky;top:0;z-index:5}
.brand{display:flex;align-items:center;gap:10px;min-width:420px}.brandLogo{width:82px;height:52px;object-fit:contain}.brand h2{margin:0;font-size:22px;line-height:1.1}.brand small{font-size:13px;color:#334155}
button{border:1px solid var(--blue);background:white;color:#064fa7;padding:8px 13px;border-radius:4px;cursor:pointer;font-weight:700;font-size:13px}.primary,button.active{background:var(--blue);color:white}button:hover{filter:brightness(.96)}
.status{font-size:12px;background:#eef3f8;padding:8px 12px;border-radius:16px;white-space:nowrap}.tab{display:none}.tab.active{display:block}
.formPage{height:calc(100vh - 68px);overflow:hidden;padding:8px 12px 10px}.searchBar{display:flex;align-items:end;gap:8px;margin-bottom:6px;background:#fff;border:1px solid #cbd6e2;padding:6px 8px}.searchBar label{display:flex;flex-direction:column;font-size:12px}.searchBar input,.warehouseLine select,.configBox input{border:1px solid #64748B;padding:6px 8px;background:#fff;font-size:13px;height:30px}.sectionTitle{display:inline-block;background:var(--navy);color:white;padding:5px 18px;font-size:18px;margin:4px 0 0 14px;position:relative;z-index:1}.warehouseLine{border:1px solid var(--line);background:#fff;margin-top:-1px;padding:8px 16px;display:flex;gap:12px;align-items:center;max-width:650px}.warehouseLine label{font-weight:bold;font-size:13px}.warehouseLine select{width:230px}
.generalBox{display:grid;grid-template-columns:230px 330px;gap:5px;max-width:590px;padding:8px 14px;background:#fff;border:1px solid var(--line);margin-top:-1px}.labelCell{border:1px solid #64748B;background:#f8fafc;padding:6px 9px;font-size:13px;font-weight:700;height:30px}.generalBox input{border:1px solid #64748B;padding:5px 8px;font-size:13px;height:30px}.opTable{border-collapse:separate;border-spacing:5px 4px;background:#fff;border:1px solid var(--line);width:100%;max-width:690px;padding:7px 14px;margin-top:-1px;margin-bottom:3px}.opTable th{background:var(--cyan);border:1px solid var(--line);padding:5px;font-size:13px}.opTable td{border:1px solid var(--line);padding:4px 8px;font-size:13px;background:#fff;height:27px}.opTable td:first-child{font-weight:700}.opTable input{border:0;width:100%;font-size:13px;height:18px;padding:0}.opTable .unit{text-align:center;background:#f8fafc}
.servicesWrap{background:#fff;border:1px solid var(--line);padding:14px 12px 8px 12px;height:calc(100vh - 462px);min-height:190px;overflow:auto;margin-top:-1px}.servicesTable{border-collapse:collapse;width:100%;font-size:12px}.servicesTable th{background:var(--cyan);border:1px solid var(--line);padding:5px;text-align:center;position:sticky;top:0;z-index:1}.servicesTable td{border:1px solid var(--line);padding:3px 6px;background:#fff;height:24px}.servicesTable .rownum{width:38px;background:var(--cyan);text-align:center;font-weight:700}.servicesTable input{width:100%;border:0;background:#fff;font-size:12px;text-align:right;height:17px;padding:0}.money{text-align:right;white-space:nowrap}.center{text-align:center}
.docWrap{height:calc(100vh - 68px);padding:8px 12px;overflow:auto}.docActions{display:flex;gap:8px;justify-content:flex-end;margin-bottom:8px}.doc{background:white;margin:0 auto 35px;border:3px solid #000;max-width:980px;min-height:760px;font-family:Arial,Helvetica,sans-serif}.cierreDoc{font-size:11px}.docHeader{display:grid;grid-template-columns:280px 1fr;align-items:center;min-height:106px;padding:14px 26px}.docLogoImg{width:215px;height:auto;object-fit:contain}.company{text-align:center;font-size:12px;line-height:1.3}.bar{background:#000;color:#fff;text-align:center;font-weight:bold;padding:5px 8px;font-size:12px}.info2{display:grid;grid-template-columns:1fr 1.35fr;gap:22px;padding:7px 12px}.infoRow{display:grid;grid-template-columns:148px 1fr;gap:5px;min-height:18px;font-size:12px}.infoRow b{font-weight:800}.infoRow span{min-height:16px}.infoRow span[contenteditable="true"]:focus,.docTable td[contenteditable="true"]:focus,.invoiceTable td[contenteditable="true"]:focus{outline:2px solid #7cc0ff;background:#eef8ff}
.docTable{width:100%;border-collapse:collapse;font-size:11px}.docTable th,.docTable td{border:1px solid #000;padding:4px}.docTable th{background:#f5f5f5;text-align:center}.docTable td:nth-child(n+3){text-align:right}.docTable tfoot td{background:var(--yellow);font-weight:bold;font-size:12px}.profit{display:flex;justify-content:space-between;background:#000;color:white;padding:6px 12px;font-size:13px;font-weight:bold}.yellow{background:var(--yellow);font-weight:bold;padding:6px 8px}.notes{height:62px;padding:8px;border-top:1px solid #000}.metricRows{width:100%;border-collapse:collapse;font-size:11px}.metricRows td{border:1px solid #000;padding:4px}.metricRows td:first-child{text-align:right;font-weight:bold}.invoiceDoc{padding:32px;max-width:860px;min-height:880px}.invoiceHeader{display:flex;justify-content:space-between;align-items:flex-start}.invoiceHeader .docLogoImg{width:220px}.invoiceNo{border:1px solid #000;text-align:center;min-width:105px;min-height:75px;padding:8px;color:#d00}.invoiceNo b{color:#000}.invoiceInfo{display:grid;grid-template-columns:1.3fr 1fr 1.35fr;border:1px solid #000;margin-top:20px;font-size:12px}.invoiceInfo>div{border-right:1px solid #000;padding:7px;min-height:88px}.invoiceInfo>div:last-child{border-right:0}.invoiceTable{width:100%;border-collapse:collapse;margin-top:16px;font-size:12px}.invoiceTable th,.invoiceTable td{border:1px solid #000;padding:6px}.invoiceTable th{background:#f8f8f8}.invoiceTable td:nth-child(n+2){text-align:right}.invoiceTotal{display:flex;justify-content:flex-end;gap:80px;margin:22px 0;font-size:13px}.bank{margin-top:22px;line-height:1.5;font-size:12px}.bank p{margin:18px 0}.docCard{background:#fff;border:1px solid #cbd6e2;margin:8px 0;padding:10px;display:flex;justify-content:space-between;gap:12px}.configBox{display:flex;flex-direction:column;gap:12px;max-width:1000px}.configBox label{font-weight:bold}.configBox input{display:block;width:100%;margin-top:4px}pre{background:#fff;border:1px solid #cbd6e2;padding:10px;overflow:auto}
@media(max-width:1150px){body{overflow:auto}.formPage{overflow:auto;height:auto}.servicesWrap{height:360px}.brand{min-width:320px}.brandLogo{width:82px}.topbar{flex-wrap:wrap;height:auto}.docWrap{height:auto}}
@media print{.no-print,.topbar,.docActions{display:none!important}body{background:#fff;overflow:visible}.tab{display:none!important}.tab.active{display:block!important}.docWrap{padding:0;height:auto;overflow:visible}.doc{margin:0 auto;max-width:980px;border:3px solid #000;box-shadow:none}.invoiceDoc{max-width:860px}.formPage{display:none!important}@page{size:letter;margin:8mm}}
