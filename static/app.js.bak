const API='';
let state={warehouses:[], rows:[], currentResult:null, currentInvoice:null, currentDocId:null, statusRaw:{}};
const opFields=[
 ['pallets','Pallets','PLT'],['weight','Gross Weight','KG'],['cbm','CBM','CBM'],['units','Inner Boxes','UNDS'],['master_boxes','Master Boxes','CTNS'],['commercial_value','Commercial Value','USD'],['pedidos_in','Inbound Orders','ORDERS'],['pedidos_out','Outbound Orders','ORDERS'],['storage_days','Storage Days','DAY'],['storage_weeks','Storage Weeks','WEEK'],['storage_months','Storage Months','MONTH']
];
function qs(id){return document.getElementById(id)}
function money(v){const n=Number(String(v??0).replace(/,/g,''));return '$'+(Number.isNaN(n)?0:n).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}
function fmt(v){const n=Number(String(v??0).replace(/,/g,''));return Number.isNaN(n)?(v||''):n.toLocaleString(undefined,{maximumFractionDigits:2})}
function num(v){const n=Number(String(v??'').replace(/,/g,''));return Number.isNaN(n)?0:n}
function setMsg(t){qs('statusMsg').textContent=t}
function setTab(tab){document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));qs(tab).classList.add('active');document.querySelectorAll('.topbar button').forEach(x=>x.classList.remove('active'));let b=qs('tabBtn_'+tab);if(b)b.classList.add('active')}
async function api(path, opts){const r=await fetch(API+path, opts);return await r.json()}
async function init(){buildOpRows(); await loadConfig(); await loadWarehouses(); setTab('formulario');}
function buildOpRows(){qs('opRows').innerHTML=opFields.map(([id,label,unit])=>`<tr><td>${label}</td><td><input id="${id}" value="0" oninput="periods()"></td><td class="unit">${unit}</td></tr>`).join('')}
function periods(){let d=num(qs('storage_days')?.value); if(qs('storage_weeks')) qs('storage_weeks').value=d?fmt(d/7):'0'; if(qs('storage_months')) qs('storage_months').value=d?fmt(d/30):'0'}
async function loadConfig(){let d=await api('/api/config');qs('aglPath').value=d.config.agl_master_path;qs('statusPath').value=d.config.status_master_path;qs('configState').textContent=JSON.stringify(d.state,null,2);setMsg(`Masters cargados | Bodegas: ${d.state.warehouses?.length||0} | Tarifas: ${d.state.rates_count||0}`)}
async function saveConfig(){let d=await api('/api/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({agl_master_path:qs('aglPath').value,status_master_path:qs('statusPath').value})});qs('configState').textContent=JSON.stringify(d,null,2);await loadWarehouses();setMsg('Rutas guardadas y masters recargados')}
async function reloadMasters(){let d=await api('/api/reload',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({force:true})});await loadConfig();await loadWarehouses();setMsg(`Recargado | ${d.rates_count} tarifas | ${d.warehouses.length} bodegas`)}
async function loadWarehouses(){let d=await api('/api/warehouses');state.warehouses=d.warehouses||[];qs('warehouse').innerHTML=state.warehouses.map(w=>`<option>${w}</option>`).join(''); if(state.warehouses.length){qs('warehouse').value=state.warehouses[0]; await loadWarehouse();}}
async function loadWarehouse(){let wh=qs('warehouse').value;qs('warehouse_display').value=wh;let d=await api('/api/warehouse/'+encodeURIComponent(wh));state.rows=d.rows||[];renderServices()}
function formData(){let f={};['operation','agl_ref','pedido'].forEach(id=>f[id]=qs(id).value);opFields.forEach(([id])=>f[id]=qs(id)?.value||'');Object.assign(f, state.statusRaw||{});return f}
function serviceQtys(){let o={};state.rows.forEach(r=>{let el=qs('qty_'+r.id); if(el) o[String(r.id)]=el.value});return o}
function renderServices(){let f=formData();qs('serviceRows').innerHTML=state.rows.map((r,i)=>{let q=suggestQty(r,f);return `<tr><td class="rownum">${i+1}</td><td>${r.agl_item||r.warehouse_item||''}</td><td><input id="qty_${r.id}" value="${q?fmt(q):''}"></td><td>${r.agl_unit||''}</td><td class="money">${money(r.sell)}</td><td class="money">${money(r.cost)}</td><td class="money">${r.minimum_agl?money(r.minimum_agl):''}</td><td class="center">${q?'✓':''}</td></tr>`}).join('')}
function suggestQty(r,f){let unit=(r.agl_unit||'').toUpperCase(), item=(r.agl_item||r.warehouse_item||'').toUpperCase(), period=(r.agl_period||'').toUpperCase();let gv=k=>num(f[k]);if(unit.includes('PALLET')||unit==='PLT')return gv('pallets');if(unit.includes('MASTER BOX')||unit.includes('CTN'))return gv('master_boxes');if(unit.includes('INNER')||unit.includes('SUB BOX')||unit.includes('PAIR')||unit.includes('UNDS'))return gv('units');if(unit.includes('CBM')){let cbm=gv('cbm');if(period.includes('MONTH')||item.includes('MONTH'))return cbm*(gv('storage_months')||1);if(period.includes('WEEK')||item.includes('WEEK'))return cbm*(gv('storage_weeks')||1);if(period.includes('DAY')||item.includes('DAY'))return cbm*(gv('storage_days')||1);return cbm}if(unit.includes('COMMERCIAL VALUE'))return gv('commercial_value');if(unit.includes('DAY'))return gv('storage_days');if(unit.includes('WEEK'))return gv('storage_weeks');if(unit.includes('MONTH'))return gv('storage_months');if(item.includes('WAREHOUSE IN')||item.endsWith(' IN')||item.includes(' IN '))return gv('pedidos_in');if(item.includes('WAREHOUSE OUT')||item.endsWith(' OUT')||item.includes(' OUT '))return gv('pedidos_out');if(item.includes('HANDLING')||item.includes('MANEJO')||unit.includes('SHIPMENT'))return 0;if(item.includes('LABEL')&&(item.includes('MASTER')||item.includes('CARTON')))return gv('master_boxes');if(item.includes('LABEL')&&(item.includes('SUB')||item.includes('INNER')))return gv('units');if(item.includes('LABEL')&&item.includes('PALLET'))return gv('pallets');if(item.includes('SEGREGATION'))return gv('master_boxes');if(item.includes('PICKING'))return gv('units');if(item.includes('PALLET'))return gv('pallets');return 0}
async function searchStatus(){let ref=qs('searchRef').value.trim()||qs('agl_ref').value.trim();if(!ref){alert('Escribe un AGL Ref');return}setMsg('Buscando en Status Master...');let d=await api('/api/status/'+encodeURIComponent(ref));if(!d.found){setMsg(d.message||'No encontrado');alert(d.message||'AGL Ref no encontrada');return}let f=d.form||{};state.statusRaw=f;qs('operation').value=f.operation||'';qs('agl_ref').value=f.agl_ref||ref;qs('pedido').value=f.pedido||f.agl_ref||ref;let map={pallets:'pallets',weight:'weight',cbm:'cbm',units:'units',master_boxes:'master_boxes',commercial_value:'commercial_value'};Object.keys(map).forEach(k=>{if(f[k]!==undefined&&f[k]!==''&&qs(map[k]))qs(map[k]).value=f[k]});periods();renderServices();setMsg(`Cargado: ${ref}${d.refreshed?' | cache actualizada':''}`)}
async function generateClosing(){let wh=qs('warehouse').value;let payload={warehouse:wh,form:formData(),service_qtys:serviceQtys()};let result=await api('/api/calculate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});state.currentResult=result;renderClosing(result);setTab('cierre')}
function info(label,value){return `<div class="infoRow"><b>${label}:</b><span contenteditable="true">${value||''}</span></div>`}
function lineRows(rows,type){return rows.map((r,i)=>`<tr>${type==='cost'?`<td>${r.provider||''}</td>`:''}<td contenteditable="${type==='sale'}">${r.item||''}</td><td contenteditable="${type==='sale'}" onblur="recalcDocTotals()">${fmt(r.qty)}</td><td>${r.unit||''}</td><td contenteditable="${type==='sale'}" onblur="recalcDocTotals()">${money(r.rate)}</td><td>${r.days||''}</td><td>${money(r.total)}</td></tr>`).join('')}
function renderClosing(r){let f=r.form||{};let html=`<div class="docHeader"><img class="docLogoImg" src="/static/agl_logo.jpg"><div class="company"><b>VÍA ESPAÑA, EDIFICIO PLAZA LIZA, PISO 3, OFICINA #2</b><br>REPÚBLICA DE PANAMÁ<br>TEL.: (507) 366-6900<br>FAX: (507) 264-4680<br>www.americagl.com</div></div><div class="bar">CIERRE DE VENTAS</div><div class="info2"><div>${info('Fecha',new Date().toISOString().slice(0,10))}${info('Para','Contabilidad')}${info('Quote No.','')}${info('Vendedor','')}${info('Elaborado por','')}${info('Agente','AGL PANAMA')}</div><div>${info('Ref. de Embarque',f.agl_ref)}${info('Bodega',r.warehouse)}${info('Cliente',f.customer)}${info('Facturar a',f.bill_to)}${info('Dirección',f.address)}${info('Teléfono',f.phone)}${info('Email',f.email)}${info('Forma de Pago',f.payment||'CONTADO')}</div></div><div class="bar">DETALLES DEL EMBARQUE</div><div class="info2"><div>${info('Origen',f.origin)}${info('Destino',f.destination)}</div><div>${info('Marca',f.brand)}${info('Descripción',f.description||'')}${info('Pallets',fmt(f.pallets)+' PLT')}${info('Peso Bruto',fmt(f.weight)+' KG')}${info('Cbm',fmt(f.cbm)+' CBM')}${info('Unidades',fmt(f.units)+' UNDS')}${info('Bultos',fmt(f.master_boxes)+' CTNS')}${info('Valor Comercial',money(f.commercial_value||0))}</div></div><div class="bar">VENTA (FACTURA)</div><table class="docTable" id="salesDoc"><thead><tr><th>ITEM</th><th>CANTIDAD</th><th>UNIDAD DE VENTA</th><th>TARIFA</th><th>DIAS</th><th>TOTAL</th></tr></thead><tbody>${lineRows(r.sales,'sale')}</tbody><tfoot><tr><td colspan="5">TOTAL A FACTURAR</td><td id="saleTotalCell">${money(r.sale_total)}</td></tr></tfoot></table><div class="bar">COSTO</div><table class="docTable"><thead><tr><th>PROVEEDOR</th><th>ITEM</th><th>CANTIDAD</th><th>UNIDAD</th><th>TARIFA</th><th>DIAS</th><th>TOTAL</th></tr></thead><tbody>${lineRows(r.costs,'cost')}</tbody><tfoot><tr><td colspan="6">TOTAL COSTO</td><td>${money(r.cost_total)}</td></tr></tfoot></table><div class="profit"><b>PROFIT</b><b id="profitCell">${money(r.profit)}</b></div><table class="metricRows"><tr><td>MARGEN</td><td id="marginCell">${r.margin_pct}%</td></tr><tr><td>FEE LOGÍSTICO</td><td id="feeCell">${r.logistics_fee_pct}%</td></tr></table><div class="yellow">Instrucciones Especiales:</div><div class="notes" contenteditable="true">${f.comments||''}</div>`;qs('closingDoc').innerHTML=html}
function recalcDocTotals(){let total=0;document.querySelectorAll('#salesDoc tbody tr').forEach(tr=>{let tds=tr.querySelectorAll('td');let qty=num(tds[1].textContent);let rate=num(tds[3].textContent);let val=qty*rate;tds[5].textContent=money(val);total+=val});let cost=state.currentResult?.cost_total||0;let profit=total-cost;qs('saleTotalCell').textContent=money(total);qs('profitCell').textContent=money(profit);qs('marginCell').textContent=(total?profit/total*100:0).toFixed(2)+'%';let cv=num(state.currentResult?.form?.commercial_value);qs('feeCell').textContent=(cv?total/cv*100:0).toFixed(2)+'%'}
function generateInvoice(){if(!state.currentResult){alert('Genera cierre primero');return}let r=state.currentResult,f=r.form||{};let rows=[...document.querySelectorAll('#salesDoc tbody tr')].map(tr=>{let td=tr.querySelectorAll('td');return {item:td[0].textContent,qty:td[1].textContent,rate:td[3].textContent,total:td[5].textContent}});let html=`<div class="invoiceHeader"><div><img class="docLogoImg" src="/static/agl_logo.jpg"><b>America Global Logistics S.A.</b><br><small>Tel. 366-69-00 - 366-6949.<br>Fax: 264-2351.<br>Via España, Plaza Liza, Piso # 3.<br>Panamá, Rep. De Panamá.<br>www.americagl.com</small></div><div class="invoiceNo"><b>Invoice No.</b><br><span contenteditable="true">${f.invoice_no||f.pedido||''}</span></div></div><div class="invoiceInfo"><div><b>Customer:</b><br><span contenteditable="true">${f.customer||''}<br>${f.address||''}<br>${f.phone||''}<br>${f.email||''}</span></div><div>${info('Origin',f.origin)}${info('Destination',f.destination)}</div><div>${info('Date',new Date().toISOString().slice(0,10))}${info('AGL Ref.',f.agl_ref)}${info('Brand',f.brand)}<div>${fmt(f.pallets)} PLTS&nbsp;&nbsp; ${fmt(f.weight)} KG&nbsp;&nbsp; ${fmt(f.cbm)} CBM</div><div>${fmt(f.units)} UNDS&nbsp;&nbsp; ${fmt(f.master_boxes)} CTNS</div></div></div><table class="invoiceTable" id="invoiceSales"><thead><tr><th>Description</th><th>Qty</th><th>Rate</th><th>Total</th></tr></thead><tbody>${rows.map(x=>`<tr><td contenteditable="true">${x.item}</td><td contenteditable="true" onblur="recalcInvoiceTotals()">${x.qty}</td><td contenteditable="true" onblur="recalcInvoiceTotals()">${x.rate}</td><td>${x.total}</td></tr>`).join('')}</tbody></table><div class="invoiceTotal"><span>USD Amount</span><b id="invoiceTotalCell">${qs('saleTotalCell')?.textContent||money(r.sale_total)}</b></div><div class="bank"><p>Please pay by Wire Transfer :</p><p><b><u>Intermediary Bank:</u></b><br>Deutsche Bank Trust Company Americas<br>Swift: BKTRUS33</p><p><b><u>Beneficiary Bank:</u></b><br>Capital Bank Inc<br>Swift: CAPBPAPA</p><p><b><u>Account:</u></b><br>Beneficiary Account Name: America Global Logistics, S.A.<br>Beneficiary Account Number: 01-202-02406-4</p></div>`;qs('invoiceDoc').innerHTML=html;state.currentInvoice={html};setTab('factura')}

function recalcInvoiceTotals(){let total=0;document.querySelectorAll('#invoiceSales tbody tr').forEach(tr=>{let tds=tr.querySelectorAll('td');let qty=num(tds[1].textContent);let rate=num(tds[2].textContent);let val=qty*rate;tds[3].textContent=money(val);total+=val});let cell=qs('invoiceTotalCell');if(cell)cell.textContent=money(total)}

async function saveCurrent(type){let html=type==='invoice'?qs('invoiceDoc').innerHTML:qs('closingDoc').innerHTML;if(!html.trim()){alert('No hay documento para guardar');return}let f=formData();let docNo=type==='invoice'?(f.invoice_no||f.pedido||'BORRADOR'):(f.closing_no||f.pedido||'BORRADOR');let payload={id:state.currentDocId,agl_ref:f.agl_ref,doc_type:type,doc_no:docNo,warehouse:qs('warehouse').value,title:`${f.agl_ref} ${type} ${docNo}`,form:f,result:state.currentResult,html};let d=await api('/api/save-document',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});state.currentDocId=d.id;setMsg(`Guardado ${type} ID ${d.id}`);alert('Documento guardado')}
async function loadDocuments(){let q=qs('docSearch').value;let d=await api('/api/documents?q='+encodeURIComponent(q));qs('documentsList').innerHTML=(d.documents||[]).map(x=>`<div class="docCard"><div><b>${x.title||''}</b><br>${x.doc_type} | ${x.agl_ref} | ${x.doc_no} | ${x.updated_at}</div><button onclick="openDocument(${x.id})">Abrir</button></div>`).join('')}
async function openDocument(id){let d=await api('/api/documents/'+id);if(!d.found){alert('No encontrado');return}let p=d.document.payload||{};state.currentDocId=id;if(p.form){Object.keys(p.form).forEach(k=>{if(qs(k))qs(k).value=p.form[k]})}if(p.result)state.currentResult=p.result;if(p.doc_type==='invoice'){qs('invoiceDoc').innerHTML=p.html||'';setTab('factura')}else{qs('closingDoc').innerHTML=p.html||'';setTab('cierre')}setMsg('Documento abierto: '+(d.document.title||id))}
window.addEventListener('load',init);
